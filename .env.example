# Copy to .env for local work or release preparation.
# Production builds should use APP_ENV=production.
APP_ENV=development

# Apps in Toss identity
# `AIT_APP_NAME` must match the app name registered in the Apps in Toss console.
AIT_APP_NAME=vocachip
AIT_DISPLAY_NAME=Vocachip
AIT_APP_ICON_URL=https://example.com/vocachip/icon.png
AIT_PRIMARY_COLOR=#1d4ed8

# Hosted legal URLs used by the Apps in Toss runtime.
VOCACHIP_PRIVACY_POLICY_URL=https://vocachip.app/legal/privacy
VOCACHIP_TERMS_OF_SERVICE_URL=https://vocachip.app/legal/terms

# Client runtime
# Production defaults disable account auth unless this is explicitly set to true.
EXPO_PUBLIC_FEATURE_ACCOUNT_AUTH=true
EXPO_PUBLIC_FEATURE_GUEST_ACCOUNT_CTA=false
EXPO_PUBLIC_FEATURE_BACKUP_RESTORE=false
EXPO_PUBLIC_FEATURE_REVIEW_LOOP=false
EXPO_PUBLIC_FEATURE_REVIEW_HOME_DASHBOARD=false
EXPO_PUBLIC_FEATURE_REVIEW_SESSION_UI=false
EXPO_PUBLIC_FEATURE_DAILY_GOAL=false
EXPO_PUBLIC_FEATURE_REVIEW_REMINDER=false
EXPO_PUBLIC_FEATURE_COLLECTIONS=false
EXPO_PUBLIC_FEATURE_FAVORITES_BATCH_ACTIONS=false
EXPO_PUBLIC_FEATURE_AI_STUDY_MODE=false
EXPO_PUBLIC_FEATURE_AI_STUDY_ENTRY_POINTS=false
EXPO_PUBLIC_FEATURE_AI_STUDY_SESSION_UI=false

# AI proxy
EXPO_PUBLIC_OPENAI_PROXY_URL=https://api.example.com
EXPO_PUBLIC_OPENAI_PROXY_KEY=replace-with-client-proxy-key
EXPO_PUBLIC_AI_HEALTH_URL=https://api.example.com/health
EXPO_PUBLIC_SENTRY_DSN=

# Server runtime
NODE_ENV=development
PORT=4000
AI_PROXY_KEY=replace-with-server-shared-secret
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3
AI_HEALTH_DEGRADED_WINDOW_MS=600000

# Optional explicit browser origins for the AI proxy.
# When `AIT_APP_NAME` is set, the server also allows:
#   https://<AIT_APP_NAME>.apps.tossmini.com
#   https://<AIT_APP_NAME>.private-apps.tossmini.com
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
